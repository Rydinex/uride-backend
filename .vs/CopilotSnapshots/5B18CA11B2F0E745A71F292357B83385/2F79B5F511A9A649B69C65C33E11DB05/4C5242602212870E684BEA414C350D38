'use client';

import { useEffect, useRef, useState } from 'react';
import L from 'leaflet';
import 'leaflet/dist/leaflet.css';
import 'leaflet-routing-machine/dist/leaflet-routing-machine.css';
import LRM from 'leaflet-routing-machine';

export default function RydinexLiveMap() {
  const mapContainer = useRef(null);
  const map = useRef(null);
  const markers = useRef(new Map());
  const polylines = useRef(new Map());
  const tileLayersRef = useRef({});
  const [activeTrips, setActiveTrips] = useState([]);
  const [selectedTrip, setSelectedTrip] = useState(null);
  const [mapLayer, setMapLayer] = useState('street');
  const socketRef = useRef(null);

  useEffect(() => {
    // Initialize map
    if (!map.current) {
      map.current = L.map(mapContainer.current).setView([40.7128, -74.006], 13);

      // Street Map Layer
      const streetLayer = L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', {
        attribution: '© OpenStreetMap contributors',
        maxZoom: 19,
      });

      // Satellite Layer (Esri)
      const satelliteLayer = L.tileLayer(
        'https://server.arcgisonline.com/ArcGIS/rest/services/World_Imagery/MapServer/tile/{z}/{y}/{x}',
        {
          attribution: '© Esri',
          maxZoom: 18,
        }
      );

      tileLayersRef.current = { street: streetLayer, satellite: satelliteLayer };
      streetLayer.addTo(map.current);
    }

    return () => {
      // Cleanup
    };
  }, []);

  useEffect(() => {
    // Initialize Socket.io connection
    const io = require('socket.io-client');
    socketRef.current = io(process.env.NEXT_PUBLIC_BACKEND_URL || 'http://localhost:4000', {
      path: '/socket.io/',
      reconnection: true,
    });

    socketRef.current.on('connect', () => {
      console.log('Connected to RydinexMaps');
    });

    socketRef.current.on('location-updated', handleLocationUpdate);
    socketRef.current.on('trip-started', handleTripStarted);
    socketRef.current.on('trip-ended', handleTripEnded);

    return () => {
      socketRef.current?.disconnect();
    };
  }, []);

  const switchLayer = (layer) => {
    setMapLayer(layer);
    // Remove current layer
    Object.values(tileLayersRef.current).forEach(tileLayer => {
      map.current.removeLayer(tileLayer);
    });
    // Add selected layer
    tileLayersRef.current[layer].addTo(map.current);
  };

  const handleLocationUpdate = (data) => {
    const { tripId, driverId, latitude, longitude, speed } = data;

    // Update driver marker
    const markerId = `driver-${driverId}`;
    const currentMarker = markers.current.get(markerId);

    if (!currentMarker) {
      const marker = L.marker([latitude, longitude], {
        icon: createDriverIcon(speed),
        title: `Driver: ${driverId}`,
      }).addTo(map.current);

      marker.bindPopup(`
        <div style="font-family: sans-serif; width: 200px;">
          <strong>Driver ${driverId}</strong><br/>
          Speed: ${speed?.toFixed(1) || 0} km/h<br/>
          Trip: ${tripId}
        </div>
      `);

      markers.current.set(markerId, marker);
    } else {
      currentMarker.setLatLng([latitude, longitude]);
      currentMarker.setIcon(createDriverIcon(speed));
    }

    // Update polyline
    addToPolyline(tripId, [latitude, longitude]);

    // Auto-pan to marker if it's selected
    if (selectedTrip === tripId) {
      map.current.panTo([latitude, longitude]);
    }
  };

  const handleTripStarted = (data) => {
    setActiveTrips(prev => [...prev, data]);
  };

  const handleTripEnded = (data) => {
    const { tripId } = data;
    setActiveTrips(prev => prev.filter(trip => trip.tripId !== tripId));
    markers.current.delete(`driver-${data.driverId}`);
  };

  const addToPolyline = (tripId, coords) => {
    let polyline = polylines.current.get(tripId);

    if (!polyline) {
      polyline = L.polyline([coords], {
        color: '#3388ff',
        weight: 3,
        opacity: 0.8,
      }).addTo(map.current);

      polylines.current.set(tripId, polyline);
    } else {
      polyline.addLatLng(coords);
    }
  };

  const createDriverIcon = (speed = 0) => {
    const speedColor = speed > 50 ? '#ff6b6b' : speed > 30 ? '#ffd93d' : '#6bcf7f';

    return L.divIcon({
      html: `
        <div style="
          background-color: ${speedColor};
          border: 2px solid white;
          border-radius: 50%;
          width: 32px;
          height: 32px;
          display: flex;
          align-items: center;
          justify-content: center;
          font-weight: bold;
          color: white;
          font-size: 12px;
          box-shadow: 0 2px 8px rgba(0,0,0,0.3);
        ">
          🚗
        </div>
      `,
      iconSize: [32, 32],
      iconAnchor: [16, 16],
      popupAnchor: [0, -16],
    });
  };

  const selectTrip = (tripId) => {
    setSelectedTrip(tripId);
    socketRef.current?.emit('request-location', { tripId });
  };

  const clearMap = () => {
    markers.current.forEach(marker => marker.remove());
    polylines.current.forEach(polyline => polyline.remove());
    markers.current.clear();
    polylines.current.clear();
  };

  return (
    <div style={{ display: 'flex', height: '100vh', fontFamily: 'system-ui, -apple-system' }}>
      {/* Sidebar */}
      <div
        style={{
          width: '320px',
          backgroundColor: '#f8f9fa',
          borderRight: '1px solid #dee2e6',
          overflowY: 'auto',
          padding: '20px',
        }}
      >
        <h2 style={{ margin: '0 0 20px', fontSize: '24px', fontWeight: 'bold' }}>
          🗺️ RydinexMaps
        </h2>

        <div style={{ marginBottom: '20px' }}>
          <button
            onClick={clearMap}
            style={{
              width: '100%',
              padding: '10px',
              backgroundColor: '#ff6b6b',
              color: 'white',
              border: 'none',
              borderRadius: '6px',
              cursor: 'pointer',
              fontWeight: '500',
            }}
          >
            Clear Map
          </button>
        </div>

        {/* Map Layer Switcher */}
        <div style={{ marginBottom: '20px' }}>
          <button
            onClick={() => switchLayer('street')}
            style={{
              width: '100%',
              padding: '10px',
              backgroundColor: mapLayer === 'street' ? '#3388ff' : 'white',
              color: mapLayer === 'street' ? 'white' : '#000',
              border: '1px solid #dee2e6',
              borderRadius: '6px',
              cursor: 'pointer',
              fontWeight: '500',
              transition: 'all 0.2s',
            }}
          >
            {mapLayer === 'street' ? '✔️' : ''} Street View
          </button>
          <button
            onClick={() => switchLayer('satellite')}
            style={{
              width: '100%',
              padding: '10px',
              marginTop: '10px',
              backgroundColor: mapLayer === 'satellite' ? '#3388ff' : 'white',
              color: mapLayer === 'satellite' ? 'white' : '#000',
              border: '1px solid #dee2e6',
              borderRadius: '6px',
              cursor: 'pointer',
              fontWeight: '500',
              transition: 'all 0.2s',
            }}
          >
            {mapLayer === 'satellite' ? '✔️' : ''} Satellite View
          </button>
        </div>

        <h3 style={{ margin: '0 0 10px', fontSize: '16px', fontWeight: '600' }}>
          Active Trips ({activeTrips.length})
        </h3>

        <div style={{ display: 'flex', flexDirection: 'column', gap: '8px' }}>
          {activeTrips.map(trip => (
            <button
              key={trip.tripId}
              onClick={() => selectTrip(trip.tripId)}
              style={{
                padding: '12px',
                backgroundColor: selectedTrip === trip.tripId ? '#3388ff' : 'white',
                color: selectedTrip === trip.tripId ? 'white' : '#000',
                border: '1px solid #dee2e6',
                borderRadius: '6px',
                cursor: 'pointer',
                textAlign: 'left',
                transition: 'all 0.2s',
              }}
              onMouseOver={e => {
                e.target.style.boxShadow = '0 2px 8px rgba(0,0,0,0.1)';
              }}
              onMouseOut={e => {
                e.target.style.boxShadow = 'none';
              }}
            >
              <div style={{ fontWeight: '600', fontSize: '14px' }}>
                Trip: {trip.tripId.slice(0, 8)}...
              </div>
              <div style={{ fontSize: '12px', opacity: 0.7 }}>
                Driver: {trip.driverId.slice(0, 6)}...
              </div>
              <div style={{ fontSize: '12px', opacity: 0.7 }}>
                Rider: {trip.riderId.slice(0, 6)}...
              </div>
            </button>
          ))}
        </div>
      </div>

      {/* Map */}
      <div
        ref={mapContainer}
        style={{
          flex: 1,
          position: 'relative',
        }}
      />

      {/* Stats Panel */}
      {selectedTrip && (
        <div
          style={{
            position: 'absolute',
            bottom: '20px',
            right: '20px',
            backgroundColor: 'white',
            padding: '16px',
            borderRadius: '8px',
            boxShadow: '0 4px 12px rgba(0,0,0,0.15)',
            minWidth: '240px',
            fontFamily: 'system-ui',
          }}
        >
          <h4 style={{ margin: '0 0 12px', fontSize: '14px', fontWeight: '600' }}>
            Trip Stats
          </h4>
          <div style={{ fontSize: '13px', display: 'flex', flexDirection: 'column', gap: '8px' }}>
            <div>
              <span style={{ opacity: 0.6 }}>Distance:</span> <strong>0.0 km</strong>
            </div>
            <div>
              <span style={{ opacity: 0.6 }}>Duration:</span> <strong>0 min</strong>
            </div>
            <div>
              <span style={{ opacity: 0.6 }}>Avg Speed:</span> <strong>0.0 km/h</strong>
            </div>
            <div>
              <span style={{ opacity: 0.6 }}>Max Speed:</span> <strong>0.0 km/h</strong>
            </div>
          </div>
        </div>
      )}
    </div>
  );
}
