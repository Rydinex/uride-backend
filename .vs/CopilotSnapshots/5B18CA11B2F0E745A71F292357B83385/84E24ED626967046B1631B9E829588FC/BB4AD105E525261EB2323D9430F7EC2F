    borderRadius: 8,
    alignItems: 'center',
    shadowColor: '#000',
    shadowOffset: { width: 0, height: 2 },
    shadowOpacity: 0.25,
    shadowRadius: 3.84,
    elevation: 5,
  },
  speedValue: {
    fontSize: 28,
    fontWeight: 'bold',
    color: 'white',
  },
  speedUnit: {
    fontSize: 12,
